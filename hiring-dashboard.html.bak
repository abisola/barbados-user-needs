// ── HELPERS ───────────────────────────────────────────────────────────────────

const totalRequired = roles.reduce((s, r) => s + r.total, 0);
const totalInPlace = roles.reduce((s, r) => s + r.inPlace, 0);
const totalRemaining = roles.reduce((s, r) => s + r.remaining, 0);
const pctFilled = Math.round((totalInPlace / totalRequired) * 100);

function formatDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
}

function daysUntil(iso) {
  const now = new Date("2026-04-10");
  const target = new Date(iso);
  const diff = Math.ceil((target - now) / 86400000);
  return diff;
}

function urgencyBadge(days) {
  if (days <= 0) return `<span class="badge badge-danger">Started</span>`;
  if (days <= 14) return `<span class="badge badge-danger">${days}d away</span>`;
  if (days <= 30) return `<span class="badge badge-warning">${days}d away</span>`;
  return `<span class="badge badge-info">${days}d away</span>`;
}

function phaseClass(phase) {
  if (phase === "Discovery") return "phase-discovery";
  if (phase === "Deep Transformation") return "phase-deep-trans";
  if (phase === "Platform Expansion") return "phase-platform";
  return "phase-consulting";
}

function priorityColor(pct) {
  if (pct >= 80) return "var(--danger)";
  if (pct >= 50) return "var(--warning)";
  return "var(--success)";
}

// ── RENDER ────────────────────────────────────────────────────────────────────

function render() {
  const app = document.getElementById("app");

  // Summary stats
  const teamsStartingSoon = teams.filter(t => daysUntil(t.startDate) <= 30 && daysUntil(t.startDate) > 0).length;
  const teamsStarted = teams.filter(t => daysUntil(t.startDate) <= 0).length;
  const categories = [...new Set(roles.map(r => r.category))];

  app.innerHTML = `
    <!-- Tabs -->
    <div class="tab-nav">
      <button class="tab-btn active" data-tab="overview" onclick="switchTab('overview')">Overview</button>
      <button class="tab-btn" data-tab="teams" onclick="switchTab('teams')">Team Rosters</button>
      <button class="tab-btn" data-tab="hiring" onclick="switchTab('hiring')">HR Hiring Priorities</button>
      <button class="tab-btn" data-tab="gantt" onclick="switchTab('gantt')">Timeline</button>
    </div>

    <!-- OVERVIEW TAB -->
    <div class="tab-content active" id="tab-overview">
      <div class="summary-grid">
        <div class="stat-card highlight">
          <div class="stat-label">Total Positions</div>
          <div class="stat-value">${totalRequired}</div>
          <div class="stat-detail">Across ${teams.length} teams</div>
        </div>
        <div class="stat-card success-highlight">
          <div class="stat-label">In Place</div>
          <div class="stat-value" style="color: var(--success)">${totalInPlace}</div>
          <div class="stat-detail">${pctFilled}% filled</div>
          <div class="progress-bar-bg">
            <div class="progress-bar-fill" style="width: ${pctFilled}%; background: var(--success)"></div>
          </div>
        </div>
        <div class="stat-card danger-highlight">
          <div class="stat-label">Still to Hire</div>
          <div class="stat-value" style="color: var(--danger)">${totalRemaining}</div>
          <div class="stat-detail">${100 - pctFilled}% of workforce</div>
        </div>
        <div class="stat-card warning-highlight">
          <div class="stat-label">Teams Starting &le; 30 Days</div>
          <div class="stat-value" style="color: var(--warning)">${teamsStartingSoon}</div>
          <div class="stat-detail">${teamsStarted} already started</div>
        </div>
      </div>

      <!-- Roles overview table -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Roles Overview</div>
            <div class="card-subtitle">All positions required across the programme</div>
          </div>
          <div class="filter-row" id="category-filters">
            <button class="filter-chip active" onclick="filterCategory('All')">All</button>
            ${categories.map(c => `<button class="filter-chip" onclick="filterCategory('${c}')">${c}</button>`).join("")}
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Role</th>
                <th class="centre">Category</th>
                <th class="right">Required</th>
                <th class="right">In Place</th>
                <th class="right">Remaining</th>
                <th class="centre" style="min-width:140px">Fill Rate</th>
              </tr>
            </thead>
            <tbody id="roles-tbody">
              ${renderRolesRows(roles)}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- TEAMS TAB -->
    <div class="tab-content" id="tab-teams">
      <div class="card-header" style="background:transparent;border:none;padding:0 0 20px;">
        <div>
          <div class="card-title">Team Rosters</div>
          <div class="card-subtitle">Roles needed per team, sorted by projected start date</div>
        </div>
        <div class="filter-row" id="phase-filters">
          <button class="filter-chip active" onclick="filterPhase('All')">All phases</button>
          <button class="filter-chip" onclick="filterPhase('Discovery')">Discovery</button>
          <button class="filter-chip" onclick="filterPhase('Deep Transformation')">Deep Transformation</button>
          <button class="filter-chip" onclick="filterPhase('Platform Expansion')">Platform Expansion</button>
          <button class="filter-chip" onclick="filterPhase('Consulting')">Consulting</button>
        </div>
      </div>
      <div class="team-grid" id="team-grid">
        ${renderTeamCards(teams)}
      </div>
    </div>

    <!-- HIRING PRIORITIES TAB -->
    <div class="tab-content" id="tab-hiring">
      <div class="summary-grid" style="grid-template-columns: repeat(auto-fit, minmax(240px,1fr));">
        <div class="stat-card danger-highlight">
          <div class="stat-label">Highest Urgency Role</div>
          <div class="stat-value" style="font-size:22px; color:var(--danger)">User Researcher</div>
          <div class="stat-detail">16 needed &ndash; none in place</div>
        </div>
        <div class="stat-card warning-highlight">
          <div class="stat-label">Largest Hire Volume</div>
          <div class="stat-value" style="font-size:22px; color:var(--warning)">Full Stack Engineer</div>
          <div class="stat-detail">16 remaining of 22 required</div>
        </div>
        <div class="stat-card highlight">
          <div class="stat-label">Lead Roles Unfilled</div>
          <div class="stat-value">${roles.filter(r => r.isLead && r.remaining > 0).length}</div>
          <div class="stat-detail">${roles.filter(r => r.isLead).reduce((s,r) => s + r.remaining, 0)} positions total</div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Hiring Priority List</div>
            <div class="card-subtitle">Ranked by urgency: roles with 0% fill rate and high volume first, then by remaining count</div>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th style="width:40px" class="centre">#</th>
                <th>Role</th>
                <th class="centre">Urgency</th>
                <th class="right">Required</th>
                <th class="right">In Place</th>
                <th class="right">To Hire</th>
                <th style="min-width:150px">Hiring Gap</th>
                <th>Needed By Teams</th>
              </tr>
            </thead>
            <tbody>
              ${renderPriorityRows()}
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Hiring Timeline</div>
            <div class="card-subtitle">When roles are needed based on team start dates</div>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Month</th>
                <th class="right">New Roles Needed</th>
                <th class="right">Cumulative</th>
                <th>Teams Starting</th>
              </tr>
            </thead>
            <tbody>
              ${renderTimelineRows()}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- GANTT TIMELINE TAB -->
    <div class="tab-content" id="tab-gantt">
      <div class="card-header" style="background:transparent;border:none;padding:0 0 16px;">
        <div>
          <div class="card-title">Programme Timeline</div>
          <div class="card-subtitle">When each team is projected to become operational &ndash; scroll horizontally for the full timeline</div>
        </div>
      </div>
      ${renderGantt()}
      <div id="gantt-tooltip" class="gantt-tooltip"></div>
    </div>
  `;

  // Attach gantt tooltip listeners after render
  setTimeout(initGanttTooltips, 0);
}

function renderGantt() {
  const sorted = [...teams].sort((a, b) => new Date(a.startDate) - new Date(b.startDate));

  // Timeline range: 2026-03-23 (first week header in spreadsheet) to 2026-10-05
  const timelineStart = new Date("2026-03-23");
  const timelineEnd = new Date("2026-10-05");
  const today = new Date("2026-04-10");

  // Generate weeks
  const weeks = [];
  let d = new Date(timelineStart);
  while (d < timelineEnd) {
    weeks.push(new Date(d));
    d.setDate(d.getDate() + 7);
  }

  // Generate month headers with col spans
  const months = [];
  let currentMonth = "";
  weeks.forEach((w, i) => {
    const m = w.toLocaleDateString("en-GB", { month: "long" });
    if (m !== currentMonth) {
      months.push({ name: m, start: i, span: 1 });
      currentMonth = m;
    } else {
      months[months.length - 1].span++;
    }
  });

  // Phase colours for bars
  const phaseColors = {
    "Discovery": "#7c3aed",
    "Deep Transformation": "#db2777",
    "Platform Expansion": "#059669",
    "Consulting": "#b45309",
  };

  // Group teams by phase for display
  const phaseOrder = ["Discovery", "Consulting", "Deep Transformation", "Platform Expansion"];
  const grouped = phaseOrder.map(p => ({
    phase: p,
    teams: sorted.filter(t => t.phase === p)
  })).filter(g => g.teams.length > 0);

  // Build header rows
  let monthHeaderCells = '<th class="gantt-label-col" style="border-bottom:none"></th><th class="gantt-size-col" style="border-bottom:none"></th>';
  months.forEach(m => {
    monthHeaderCells += '<th colspan="' + m.span + '" style="border-left:1px solid var(--border)">' + m.name + '</th>';
  });

  let weekHeaderCells = '<th class="gantt-label-col">Team</th><th class="gantt-size-col">Size</th>';
  weeks.forEach(w => {
    const day = w.getDate();
    const isToday = Math.abs(w - today) < 3.5 * 86400000;
    weekHeaderCells += '<th class="gantt-week-col' + (isToday ? '" style="color:var(--danger);font-weight:700' : '') + '">' + day + '</th>';
  });

  // Today line position
  const todayOffset = (today - timelineStart) / (7 * 86400000);
  const weekWidth = 44; // matches min-width
  const todayPx = todayOffset * weekWidth;

  // Build body rows
  let bodyRows = "";
  grouped.forEach(g => {
    // Phase separator row
    bodyRows += '<tr class="gantt-phase-row"><td class="gantt-label-cell" style="background:var(--border-light) !important">' + g.phase + '</td><td class="gantt-size-cell" style="background:var(--border-light) !important"></td>';
    weeks.forEach(() => { bodyRows += '<td></td>'; });
    bodyRows += '</tr>';

    g.teams.forEach(t => {
      const teamSize = t.roles.reduce((s, r) => s + r.count, 0);
      const startD = new Date(t.startDate);
      const barStartWeek = (startD - timelineStart) / (7 * 86400000);
      // Each team bar spans ~8 weeks as an operational window estimate
      const barWidthWeeks = 8;
      const barLeft = barStartWeek * weekWidth;
      const barWidth = barWidthWeeks * weekWidth;
      const color = phaseColors[t.phase] || "var(--primary)";
      const days = daysUntil(t.startDate);
      const roleList = t.roles.map(r => r.name + (r.count > 1 ? " ×" + r.count : "")).join(", ");

      bodyRows += '<tr>';
      bodyRows += '<td class="gantt-label-cell"><span style="font-weight:600;font-size:13px">' + t.name + '</span></td>';
      bodyRows += '<td class="gantt-size-cell">' + teamSize + '</td>';

      // Render cells; the bar is positioned absolutely in the first week cell's row
      weeks.forEach((w, i) => {
        if (i === 0) {
          bodyRows += '<td class="gantt-week-cell" style="position:relative">';
          bodyRows += '<div class="gantt-bar-wrap" style="left:' + barLeft + 'px;width:' + barWidth + 'px;background:' + color + ';" data-team="' + t.name + '" data-start="' + formatDate(t.startDate) + '" data-size="' + teamSize + '" data-roles="' + roleList.replace(/"/g, "&quot;") + '" data-days="' + days + '">';
          bodyRows += '<span class="gantt-bar-label">' + t.name + '</span>';
          bodyRows += '</div>';
          // Today line
          bodyRows += '<div class="gantt-today-line" style="left:' + todayPx + 'px"><span class="gantt-today-label">Today</span></div>';
          bodyRows += '</td>';
        } else {
          bodyRows += '<td class="gantt-week-cell"></td>';
        }
      });
      bodyRows += '</tr>';
    });
  });

  return '<div class="gantt-container">' +
    '<div class="gantt-scroll">' +
    '<table class="gantt-table">' +
    '<thead>' +
    '<tr class="gantt-month-header">' + monthHeaderCells + '</tr>' +
    '<tr>' + weekHeaderCells + '</tr>' +
    '</thead>' +
    '<tbody>' + bodyRows + '</tbody>' +
    '</table>' +
    '</div>' +
    '<div class="gantt-legend">' +
    '<span style="font-weight:600;color:var(--text)">Phases:</span>' +
    Object.entries(phaseColors).map(([name, color]) =>
      '<span class="gantt-legend-item"><span class="gantt-legend-dot" style="background:' + color + '"></span>' + name + '</span>'
    ).join("") +
    '<span class="gantt-legend-item" style="margin-left:auto"><span style="width:2px;height:12px;background:var(--danger);border-radius:1px;display:inline-block"></span> Today (10 Apr)</span>' +
    '</div>' +
    '</div>';
}

function initGanttTooltips() {
  const tooltip = document.getElementById("gantt-tooltip");
  if (!tooltip) return;

  document.querySelectorAll(".gantt-bar-wrap").forEach(bar => {
    bar.addEventListener("mouseenter", (e) => {
      const name = bar.dataset.team;
      const start = bar.dataset.start;
      const size = bar.dataset.size;
      const roles = bar.dataset.roles;
      const days = parseInt(bar.dataset.days);
      const status = days <= 0 ? "Already started" : days + " days until start";

      tooltip.innerHTML =
        '<div style="font-weight:700;font-size:13px;margin-bottom:4px">' + name + '</div>' +
        '<div style="margin-bottom:2px">Start: ' + start + '</div>' +
        '<div style="margin-bottom:2px">Status: ' + status + '</div>' +
        '<div style="margin-bottom:2px">Team size: ' + size + ' positions</div>' +
        '<div style="color:#cbd5e1;margin-top:6px;font-size:11px">Roles: ' + roles + '</div>';
      tooltip.classList.add("visible");
    });

    bar.addEventListener("mousemove", (e) => {
      tooltip.style.left = (e.clientX + 12) + "px";
      tooltip.style.top = (e.clientY - 10) + "px";
    });

    bar.addEventListener("mouseleave", () => {
      tooltip.classList.remove("visible");
    });
  });
}

function renderRolesRows(roleList) {
  return roleList.map(r => {
    const pct = r.total > 0 ? Math.round((r.inPlace / r.total) * 100) : 0;
    const fillColor = pct >= 50 ? "var(--success)" : pct > 0 ? "var(--warning)" : "var(--danger)";
    return `<tr class="role-row" data-category="${r.category}">
      <td><span class="role-name ${r.isLead ? 'lead-role' : ''}">${r.name}</span></td>
      <td class="centre"><span class="badge badge-muted">${r.category}</span></td>
      <td class="right mono">${r.total}</td>
      <td class="right mono">${r.inPlace}</td>
      <td class="right mono" style="font-weight:600; color: ${r.remaining > 0 ? 'var(--danger)' : 'var(--success)'}">${r.remaining}</td>
      <td>
        <div class="priority-bar">
          <div class="priority-fill-bg">
            <div class="priority-fill" style="width:${pct}%; background:${fillColor}"></div>
          </div>
          <span style="font-size:12px;font-weight:600;color:${fillColor};min-width:36px;text-align:right">${pct}%</span>
        </div>
      </td>
    </tr>`;
  }).join("");
}

function renderTeamCards(teamList) {
  return teamList.sort((a, b) => new Date(a.startDate) - new Date(b.startDate)).map(t => {
    const totalRoles = t.roles.reduce((s, r) => s + r.count, 0);
    const days = daysUntil(t.startDate);
    return `<div class="team-card" data-phase="${t.phase}">
      <div class="team-card-header">
        <span class="team-name">${t.name}</span>
        <span class="team-phase ${phaseClass(t.phase)}">${t.phase}</span>
      </div>
      <div class="team-date">
        Projected start: <strong>${formatDate(t.startDate)}</strong> &nbsp;${urgencyBadge(days)}
      </div>
      <div class="team-roles-list">
        ${t.roles.map(r => `
          <div class="team-role-row">
            <span class="team-role-name">${r.name}</span>
            <span class="team-role-count">${r.count}</span>
          </div>
        `).join("")}
      </div>
      <div class="team-total">
        <span>Total positions</span>
        <span>${totalRoles}</span>
      </div>
    </div>`;
  }).join("");
}

function renderPriorityRows() {
  const sorted = [...roles].filter(r => r.remaining > 0).sort((a, b) => {
    const aPct = a.inPlace / a.total;
    const bPct = b.inPlace / b.total;
    if (aPct !== bPct) return aPct - bPct;
    return b.remaining - a.remaining;
  });

  return sorted.map((r, i) => {
    const pct = Math.round((r.remaining / r.total) * 100);
    const urgency = r.inPlace === 0 ? "badge-danger" : (r.inPlace / r.total) < 0.25 ? "badge-warning" : "badge-info";
    const urgencyLabel = r.inPlace === 0 ? "Critical" : (r.inPlace / r.total) < 0.25 ? "High" : "Medium";
    const teamsNeeding = teams.filter(t => t.roles.some(tr => tr.name === r.name)).map(t => t.name);
    const teamStr = teamsNeeding.length > 3
      ? teamsNeeding.slice(0, 3).join(", ") + ` +${teamsNeeding.length - 3} more`
      : teamsNeeding.join(", ");

    return `<tr>
      <td class="centre mono" style="color:var(--text-muted);font-weight:600">${i + 1}</td>
      <td><span class="role-name ${r.isLead ? 'lead-role' : ''}">${r.name}</span></td>
      <td class="centre"><span class="badge ${urgency}">${urgencyLabel}</span></td>
      <td class="right mono">${r.total}</td>
      <td class="right mono">${r.inPlace}</td>
      <td class="right mono" style="font-weight:700;color:var(--danger)">${r.remaining}</td>
      <td>
        <div class="priority-bar">
          <div class="priority-fill-bg">
            <div class="priority-fill" style="width:${pct}%; background:${priorityColor(pct)}"></div>
          </div>
          <span style="font-size:12px;font-weight:600;min-width:36px;text-align:right">${pct}%</span>
        </div>
      </td>
      <td style="font-size:12px;color:var(--text-secondary);max-width:200px">${teamStr || "–"}</td>
    </tr>`;
  }).join("");
}

function renderTimelineRows() {
  const months = {};
  teams.forEach(t => {
    const d = new Date(t.startDate);
    const key = d.toLocaleDateString("en-GB", { month: "long", year: "numeric" });
    if (!months[key]) months[key] = { count: 0, teams: [], date: d };
    const teamTotal = t.roles.reduce((s, r) => s + r.count, 0);
    months[key].count += teamTotal;
    months[key].teams.push(t.name);
  });

  let cumulative = 0;
  return Object.entries(months)
    .sort(([,a], [,b]) => a.date - b.date)
    .map(([month, data]) => {
      cumulative += data.count;
      return `<tr>
        <td style="font-weight:600">${month}</td>
        <td class="right mono">${data.count}</td>
        <td class="right mono" style="font-weight:600">${cumulative}</td>
        <td style="font-size:13px;color:var(--text-secondary)">${data.teams.join(", ")}</td>
      </tr>`;
    }).join("");
}

// ── INTERACTIONS ───────────────────────────────────────────────────────────────

function switchTab(tabId) {
  document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
  document.querySelector(`[data-tab="${tabId}"]`).classList.add("active");
  document.querySelectorAll(".tab-content").forEach(c => c.classList.remove("active"));
  document.getElementById(`tab-${tabId}`).classList.add("active");
}

function filterCategory(cat) {
  const chips = document.querySelectorAll("#category-filters .filter-chip");
  chips.forEach(c => c.classList.remove("active"));
  event.target.classList.add("active");

  const rows = document.querySelectorAll(".role-row");
  rows.forEach(r => {
    r.style.display = (cat === "All" || r.dataset.category === cat) ? "" : "none";
  });
}

function filterPhase(phase) {
  const chips = document.querySelectorAll("#phase-filters .filter-chip");
  chips.forEach(c => c.classList.remove("active"));
  event.target.classList.add("active");

  const cards = document.querySelectorAll(".team-card");
  cards.forEach(c => {
    c.style.display = (phase === "All" || c.dataset.phase === phase) ? "" : "none";
  });
}

// ── INIT ──────────────────────────────────────────────────────────────────────
render();
</script>
</body>
</html>
